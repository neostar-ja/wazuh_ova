<!--
Custom Rules maintained locally
Note: Huawei USG rules moved to 1000-huawei_rules.xml for load-order dependency.
IDs 100300-100302: CDB passive lookup (avoid conflict with 100070-100082 Huawei-AC)
IDs 100500-100520: Huawei USG general admin/system events
-->

<!-- ── Huawei USG General Log Rules (100500-100520) ─────────────────────────
     Handles %%01UM, %%01SHELL, %%01ACLM modules that are not traffic/policy events.
     Base: decoded_as huawei-usg-general
     Level: 3 default, 7 for auth failures, 5 for sync failures, 0 to suppress
-->
<group name="huawei,huawei_usg,system_event,">

  <!-- Catch-all: any Huawei USG general log (suppress noisy modules) -->
  <rule id="100500" level="3">
    <decoded_as>huawei-usg-general</decoded_as>
    <description>Huawei USG: System event [$(usg_module)/$(usg_event)] on $(usg_hostname)</description>
    <group>huawei_admin,</group>
  </rule>

  <!-- Suppress: Very high-volume UM user sync events -->
  <rule id="100501" level="0">
    <if_sid>100500</if_sid>
    <field name="usg_event">IMPORTSUCCESS|SYNCSTART|SYNCEND|CHECKPASS</field>
    <description>Huawei USG: UM user sync event (suppressed — high volume)</description>
  </rule>

  <!-- Auth failure from UM module -->
  <rule id="100502" level="7">
    <if_sid>100500</if_sid>
    <field name="usg_module">UM</field>
    <field name="usg_event">SYNCFAIL|LOGINFAILED|AUTHFAILED</field>
    <description>Huawei USG: UM authentication/sync failure — $(usg_message)</description>
    <group>authentication,authentication_failed,</group>
  </rule>

  <!-- Shell command recording (admin activity) -->
  <rule id="100503" level="5">
    <if_sid>100500</if_sid>
    <field name="usg_module">SHELL</field>
    <field name="usg_event">CMDRECORD</field>
    <description>Huawei USG: Admin command recorded on $(usg_hostname): $(usg_message)</description>
    <group>configuration_management,admin_activity,</group>
  </rule>

</group>

<group name="threat_intel,">

  <!-- ── OTX Threat Intelligence (100060-100061) ──────────────
       Triggered by custom-otx integration (real-time per alert)
       Groups: huawei, mikrotik, firewall_drop                -->

  <rule id="100060" level="8">
    <field name="otx_status">malicious</field>
    <field name="otx_pulse_count" type="pcre2">^[1-4]$</field>
    <description>OTX: Suspicious $(otx_ip_type) $(otx_ip) — $(otx_pulse_count) threat feed(s): $(otx_pulse_name)</description>
    <group>otx_intel,otx_suspicious,attacks,</group>
  </rule>

  <rule id="100061" level="12">
    <field name="otx_status">malicious</field>
    <field name="otx_pulse_count" type="pcre2">^([5-9]|[1-9][0-9]+)$</field>
    <description>OTX: MALICIOUS $(otx_ip_type) $(otx_ip) — $(otx_pulse_count) threat feeds | $(otx_pulse_name)</description>
    <group>otx_intel,otx_malicious,attacks,pci_dss_11.4,gdpr_IV_35.7.d,</group>
  </rule>

  <!-- ── CDB Passive Blocklist (100300-100302) ────────────────
       Fires on every alert matching field — no external API   -->

  <rule id="100300" level="10">
    <list field="srcip" lookup="match_key">etc/lists/malicious-ioc/malicious-ip</list>
    <description>CDB Blocklist: Source IP $(srcip) matches malicious-ip list</description>
    <group>cdb_intel,cdb_malicious_ip,attacks,pci_dss_11.4,</group>
  </rule>

  <rule id="100303" level="10">
    <if_sid>100300</if_sid>
    <match>POLICYDENY|ACCESSPOLICY_DENY|action="deny"|action="block"|action="blocked"|action="drop"|action="dropped"|action="close"|action="reset"|denied|blocked|dropped</match>
    <description>CDB Blocklist: Source IP $(srcip) matches malicious-ip list but traffic was denied/blocked</description>
    <group>cdb_intel,cdb_malicious_ip,attacks,firewall_drop,pci_dss_11.4,</group>
  </rule>

  <rule id="100301" level="10">
    <list field="dstip" lookup="match_key">etc/lists/malicious-ioc/malicious-ip</list>
    <description>CDB Blocklist: Destination IP $(dstip) matches malicious-ip list</description>
    <group>cdb_intel,cdb_malicious_ip,attacks,pci_dss_11.4,</group>
  </rule>

  <rule id="100302" level="12">
    <list field="syscheck.sha256_after" lookup="match_key">etc/lists/malicious-ioc/malware-hashes</list>
    <description>CDB Blocklist: File hash $(syscheck.sha256_after) matches known malware</description>
    <group>cdb_intel,cdb_malware_hash,malware,pci_dss_11.4,gdpr_IV_35.7.d,</group>
  </rule>

</group>
