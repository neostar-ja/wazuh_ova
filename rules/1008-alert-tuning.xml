  <!-- ════════════════════════════════════════════════════════════
       HUAWEI USG COMPLIANCE RECOVERY RULES (100512-100513)
       ════════════════════════════════════════════════════════════
       ปัญหา: เหมือนกัน FortiGate — compliance overlay (if_group) ชนะ 100051/100502
       วิธีแก้: Recovery rules เป็น if_sid children ของ compliance rule

       Discriminator: <match>%%01POLICY</match> ระบุ Huawei USG POLICY* log
                      ไม่ conflict กับ FortiGate recovery (110042 ใช้ devname=FW-WUH)

       Group ที่ต้องไม่ใส่: firewall_drop, authentication_failed (re-trigger compliance chain)
       Validated: 2026-06-01
       ════════════════════════════════════════════════════════════ -->

  <!--
    Date        : 2026-06-01
    Rule ID     : 100512
    Rule Desc   : Huawei USG POLICYDENY recovery — re-tag after compliance 120001 overrides
    Original    : 120001 level=5 (PCI DSS 1.3, no huawei_usg group)
    Tuned to    : 100512 level=5 (Huawei-tagged, deeper child → wins)
    Reason      : 120001 (if_group: firewall_drop) fires as child of 100051 and replaces
                  rule.id + rule.groups → Huawei USG deny panel shows nothing.
                  <match>%%01POLICY</match> discriminates Huawei USG POLICY* logs from
                  FortiGate logs (which use devname field, not %%01POLICY).
    Requester   : SOC Admin
    Approved by : SOC Admin
    Review date : 2026-09-01
    Status      : active
  -->
  <rule id="100512" level="5">
    <if_sid>120001</if_sid>
    <match>%%01POLICY</match>
    <description>Huawei USG: Traffic DENIED $(srcip):$(srcport) → $(dstip):$(dstport) [$(protocol)]</description>
    <group>huawei,firewall,huawei_usg,access_denied,pci_dss_1.3,nist_800_53_CM.7,compliance,</group>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>

  <!--
    Date        : 2026-06-01
    Rule ID     : 100513
    Rule Desc   : Huawei USG UM auth failure recovery — re-tag after compliance 120003 overrides
    Original    : 120003 level=7 (PCI DSS 8.3, no huawei_usg group)
    Tuned to    : 100513 level=7 (Huawei-tagged, deeper child → wins)
    Reason      : 120003 (if_group: authentication_failed) fires as child of 100502 and
                  replaces rule.id + rule.groups.
                  <match>%%01UM</match> discriminates Huawei USG UM auth logs.
    Requester   : SOC Admin
    Approved by : SOC Admin
    Review date : 2026-09-01
    Status      : active
  -->
  <rule id="100513" level="7">
    <if_sid>120003</if_sid>
    <match>%%01UM</match>
    <description>Huawei USG: UM authentication/sync failure — $(usg_message)</description>
    <group>huawei,huawei_usg,system_event,pci_dss_8.3,hipaa_164.308.a.5.ii.c,nist_800_53_AC.3,tsc_CC6.1,compliance,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- ════════════════════════════════════════════════════════════
       HUAWEI AC COMPLIANCE RECOVERY RULES (100083-100084)
       ════════════════════════════════════════════════════════════
       ปัญหา: 36K+ auth failure events/6h แสดงเป็น 120003 (compliance)
              แทน 100071/100073 (Huawei AC) เพราะ if_group: authentication_failed

       Discriminator: <match>AgileController</match>
         - Huawei USG recovery ใช้ %%01POLICY → ไม่ conflict
         - FortiGate recovery ใช้ devname=FW-WUH → ไม่ conflict
         - Infoblox ไม่มี authentication_failed → ไม่ต้อง recovery

       Dashboard impact: decoder.name: "huawei-ac" filter ยังเห็น events แต่
         rule.id/description ผิด → recovery ทำให้ถูกต้อง
       Validated: 2026-06-01
       ════════════════════════════════════════════════════════════ -->

  <!--
    Date        : 2026-06-01
    Rule ID     : 100083
    Rule Desc   : Huawei AC auth failure recovery — re-tag after compliance 120003 overrides
    Original    : 120003 level=7 (PCI DSS 8.3, no huawei_ac group)
    Tuned to    : 100083 level=7 (Huawei AC-tagged, deeper child → wins)
    Reason      : 120003 (if_group: authentication_failed) fires as child of 100071/100073
                  replacing rule.id + rule.groups. 36K+ events/6h show as compliance rule.
                  <match>AgileController</match> discriminates Huawei AC logs.
                  Does NOT include authentication_failed group (avoids re-triggering compliance chain).
    Requester   : SOC Admin
    Approved by : SOC Admin
    Review date : 2026-09-01
    Status      : active
  -->
  <rule id="100083" level="7">
    <if_sid>120003</if_sid>
    <match>AgileController</match>
    <description>Huawei AC: Authentication failed — $(dstuser) from $(srcip) [$(switch_name)]</description>
    <group>huawei,huawei_ac,wireless,pci_dss_8.3,hipaa_164.308.a.5.ii.c,nist_800_53_AC.3,tsc_CC6.1,compliance,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!--
    Date        : 2026-06-01
    Rule ID     : 100084
    Rule Desc   : Huawei AC brute force recovery — re-tag after compliance 120004 overrides
    Original    : 120004 level=12 (PCI DSS 8.3 brute force, no huawei_ac group)
    Tuned to    : 100084 level=12 (Huawei AC-tagged, deeper child → wins)
    Reason      : 120004 (if_group: brute_force) fires as child of 100074.
                  Preventive recovery rule — no occurrences observed yet but correct as a safeguard.
    Requester   : SOC Admin
    Approved by : SOC Admin
    Review date : 2026-09-01
    Status      : active
  -->
  <rule id="100084" level="12">
    <if_sid>120004</if_sid>
    <match>AgileController</match>
    <description>Huawei AC: BRUTE FORCE — repeated auth failures from $(srcip) [$(switch_name)]</description>
    <group>huawei,huawei_ac,wireless,pci_dss_8.3,compliance,</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!--
    Date        : 2026-06-02
    Rule ID     : 100303
    Rule Desc   : CDB Blocklist: Source IP matches malicious-ip list but traffic was denied/blocked
    Original    : level=10 (triggers AbuseIPDB + Telegram via worker integration level≥10)
    Tuned to    : level=8  (Dashboard only — blocked traffic requires no Telegram; already handled)
    Reason      : Worker ossec.conf integration custom-abuseipdb triggers at level≥10.
                  Rule 100303 at level 10 causes Telegram for BLOCKED traffic, which is unnecessary
                  noise — the firewall already mitigated the threat.
                  Level 8 keeps the event visible in Dashboard (MEDIUM tier) but below the
                  integration threshold, so no Telegram or AbuseIPDB API call is wasted.
                  Rule 100304 (new, level 15) handles the inverse case (ALLOWED malicious) with
                  CRITICAL priority. Rule 100300 (level 10, ambiguous) still triggers AbuseIPDB.
    Requester   : SOC Admin
    Approved by : SOC Admin
    Review date : 2026-09-02
    Ticket/Ref  : -
    Status      : active
  -->
  <rule id="100303" level="8" overwrite="yes">
    <if_sid>100300</if_sid>
    <match>POLICYDENY|ACCESSPOLICY_DENY|action="deny"|action="block"|action="blocked"|action="drop"|action="dropped"|action="close"|action="reset"|denied|blocked|dropped</match>
    <description>CDB Blocklist: Source IP $(srcip) blocked by firewall (no Telegram — already mitigated)</description>
    <group>cdb_intel,cdb_malicious_ip,firewall_drop,pci_dss_11.4,</group>
  </rule>

