<!--
════════════════════════════════════════════════════════════════════════════════
  WAZUH ALERT TUNING REGISTER
  ไฟล์   : rules/1008-alert-tuning.xml
  โหลดหลัง: 1007-compliance-tags.xml (load order ทำให้ override มีผล)
  หน้าที่ : รวม rule level overrides ทั้งหมดไว้ที่เดียว
  หลักการ :
    1. ห้ามแก้ไขไฟล์ rule หลัก (1000-1007, local_rules.xml) โดยตรง
    2. ทุก override ต้องใช้ overwrite="yes" ในไฟล์นี้เท่านั้น
    3. ทุก override ต้องมี tuning log ครบถ้วน (ดู template ด้านล่าง)
    4. Review date ต้องกรอกทุกครั้ง (แนะนำ 30-90 วัน)
    5. ต้องคัดลอก compliance tags จาก rule เดิมทุกตัว
  ผู้ดูแล : SOC Team
════════════════════════════════════════════════════════════════════════════════

  LEVEL GUIDE — ผลต่อ Telegram:
    Level 15+    → 🔴 CRITICAL  ส่ง Telegram ทันที
    Level 12-14  → 🟠 HIGH      ส่ง Telegram
    Level 8-11   → 📋 MEDIUM    Dashboard + Compliance เท่านั้น (ไม่ส่ง Telegram)
    Level 4-7    → 🔵 LOW       Dashboard เท่านั้น
    Level 0-3    → ⚪ INFO      Archives เท่านั้น (ไม่ขึ้น Dashboard)

  TUNING LOG TEMPLATE — คัดลอกและกรอกทุกครั้งที่เพิ่ม override ใหม่:

    Date        : YYYY-MM-DD
    Rule ID     : XXXXX
    Rule Desc   : [description จาก rule เดิม]
    Original    : level=XX
    Tuned to    : level=YY
    Reason      : [อธิบายว่าทำไม — false positive? noise? environment-specific?]
    Requester   : [ชื่อหรือ role ของผู้ขอ]
    Approved by : [ชื่อผู้อนุมัติ ถ้ามี]
    Review date : YYYY-MM-DD [วันที่ควร review — แนะนำ 90 วัน]
    Ticket/Ref  : [เลข ticket หรือ - ถ้าไม่มี]
    Status      : active | expired | reverted

════════════════════════════════════════════════════════════════════════════════
-->

<group name="tuned,">

  <!-- ════════════════════════════════════════════════════════════
       ACTIVE TUNING RULES
       ════════════════════════════════════════════════════════════ -->

  <!--
    Date        : 2026-05-19
    Rule ID     : 120061
    Rule Desc   : NIST SC.5 / TSC CC7.2: DHCP pool exhausted
    Original    : level=13 (ส่ง Telegram 🔴 CRITICAL)
    Tuned to    : level=8  (Dashboard + Compliance เท่านั้น ไม่ส่ง Telegram)
    Reason      : DHCP pool exhaustion เกิดจากจำนวน IP device ปกติใน network
                  ไม่ใช่ DHCP starvation attack จริง เหตุการณ์เกิดซ้ำทุกวัน
                  ยังต้องการ visibility ใน Dashboard และ Compliance แต่ไม่ต้องการ
                  Telegram notification ที่รบกวน ควร review อีกครั้งถ้า network
                  topology เปลี่ยน หรือถ้าเห็น DHCP conflict ร่วมด้วย
    Requester   : SOC Admin
    Approved by : SOC Admin
    Review date : 2026-08-19
    Ticket/Ref  : -
    Status      : active
  -->
  <rule id="120061" level="8" overwrite="yes">
    <if_sid>100441,100442</if_sid>
    <description>NIST SC.5 / TSC CC7.2: DHCP pool exhausted (tuned: infra noise, not attack)</description>
    <group>nist_800_53_SC.5,tsc_CC7.2,compliance,dhcp,dos,tuned,</group>
  </rule>

  <!--
    Date        : 2026-05-31
    Rule ID     : 110041
    Rule Desc   : FortiGate local-in-policy deny (IPv6 multicast/mDNS/broadcast noise)
    Original    : rule 120001 level=5 (fires for all firewall_drop via if_group)
    Tuned to    : level=0 (suppress)
    Reason      : FortiGate generates ~600 local-in-policy deny/sec for IPv6 multicast
                  (ff02::/16, mDNS 5353, LLMNR 5355, DHCP6) and IPv4 broadcast.
                  policytype="local-in-policy" and "local-in-policy6" are normal
                  infrastructure behavior, not security events.
                  Keeps forward-deny (policytype="policy") visible via rule 120001.
    Requester   : SOC Admin
    Approved by : SOC Admin
    Review date : 2026-08-31
    Ticket/Ref  : -
    Status      : active
  -->
  <rule id="110041" level="0">
    <if_sid>120001</if_sid>
    <match>policytype="local-in-policy</match>
    <description>FortiGate WUH: Local-in-policy DENY suppressed (infrastructure noise)</description>
    <group>firewall_drop,local_policy,tuned,</group>
  </rule>

  <!-- ════════════════════════════════════════════════════════════
       FORTIGATE COMPLIANCE RECOVERY RULES (110042-110045)
       ════════════════════════════════════════════════════════════
       ปัญหา: Compliance overlay rules (if_group) ใน 1007-compliance-tags.xml
              เป็น "deeper child" เสมอ → ชนะ FortiGate rules และแทนที่
              rule.id + rule.groups ทำให้ FortiGate dashboard หา events ไม่เจอ

       วิธีแก้: Recovery rules เป็นลูกของ compliance rule อีกต่อ (if_sid) →
               deeper ที่สุดใน chain → ชนะ → alert มี fortigate_wuh group กลับมา

       สิ่งที่ต้องไม่ใส่ใน group ของ recovery rules:
         firewall_drop, authentication_failed, admin_login, config_changed, brute_force
         (ป้องกันการ trigger compliance chain ซ้ำ)

       Validated: 2026-06-01
       ════════════════════════════════════════════════════════════ -->

  <!--
    Date        : 2026-06-01
    Rule ID     : 110042
    Rule Desc   : FortiGate traffic DENY recovery — re-tag after compliance 120001 overrides
    Original    : 120001 level=5 (PCI DSS 1.3, compliance overlay, no fortigate_wuh group)
    Tuned to    : 110042 level=5 (FortiGate-tagged, deeper child → wins over 120001)
    Reason      : 120001 (if_group: firewall_drop) fires as child of 110012 and replaces
                  rule.id + rule.groups → FortiGate dashboard shows no traffic deny events.
                  Recovery rule fires as child of 120001 (if_sid) and is deeper → wins.
                  policytype="policy" excludes local-in-policy (suppressed by 110041).
                  Does NOT include firewall_drop group (avoids re-triggering 120001).
    Requester   : SOC Admin
    Approved by : SOC Admin
    Review date : 2026-09-01
    Ticket/Ref  : -
    Status      : active
  -->
  <rule id="110042" level="5">
    <if_sid>120001</if_sid>
    <field name="devname">^FW-WUH</field>
    <match>policytype="policy"</match>
    <description>FortiGate WUH: Traffic DENIED $(srcip) → $(dstip):$(dstport) [$(service)]</description>
    <group>fortigate,firewall,fortigate_wuh,pci_dss_1.3,nist_800_53_CM.7,compliance,</group>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>

  <!--
    Date        : 2026-06-01
    Rule ID     : 110043
    Rule Desc   : FortiGate admin login FAIL recovery — re-tag after compliance 120003 overrides
    Original    : 120003 level=7 (PCI DSS 8.3, compliance overlay, no fortigate_wuh group)
    Tuned to    : 110043 level=7 (FortiGate-tagged, deeper child → wins over 120003)
    Reason      : 120003 (if_group: authentication_failed) fires as child of 110034 and
                  replaces FortiGate context. Recovery restores FortiGate identity while
                  preserving all compliance tags (PCI 8.3, HIPAA 164.308, NIST AC.3, TSC CC6.1).
                  Does NOT include authentication_failed group (avoids re-triggering compliance chain).
    Requester   : SOC Admin
    Approved by : SOC Admin
    Review date : 2026-09-01
    Ticket/Ref  : -
    Status      : active
  -->
  <rule id="110043" level="7">
    <if_sid>120003</if_sid>
    <field name="devname">^FW-WUH</field>
    <description>FortiGate WUH: Admin LOGIN FAILED from $(srcip) [$(devname)]</description>
    <group>fortigate,firewall,fortigate_wuh,pci_dss_8.3,hipaa_164.308.a.5.ii.c,nist_800_53_AC.3,tsc_CC6.1,compliance,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

