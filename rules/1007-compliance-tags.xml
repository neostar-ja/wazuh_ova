<!-- Compliance overlay rules: PCI DSS 3.2.1 | HIPAA | GDPR | NIST 800-53 | TSC (SOC2)
     Rule IDs: 120001-120044 (reserved for compliance)
     Format: compliance tags embedded in <group> as pci_dss_X.X, hipaa_X, gdpr_IV_X, etc.
     Deployed: 2026-05-18
-->
<group name="compliance,">

  <!-- ============================================================
       PCI DSS v3.2.1 — Payment Card Industry Data Security Standard
  ============================================================ -->

  <!-- PCI 1.3: Prohibit direct public access -->
  <!-- level=5 matches the underlying deny rules so the alert is visible.
       This rule fires AFTER the underlying firewall_drop rule in the chain
       and replaces it with PCI DSS tagging. level=0 would suppress the alert. -->
  <rule id="120001" level="5">
    <if_group>firewall_drop</if_group>
    <description>PCI DSS 1.3: Unauthorized network access blocked from $(srcip) → $(dstip):$(dstport)</description>
    <group>pci_dss_1.3,compliance,firewall,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- PCI 6.6: Web application attacks -->
  <rule id="120002" level="8">
    <!-- Wazuh concatenates repeated <if_group> tags into an invalid group name.
         Keep a single IDS anchor and narrow the match with Suricata attack metadata. -->
    <if_group>ids</if_group>
    <match>Web Application Attack|Attempted Administrator Privilege Gain|Exploit|ET WEB_SERVER</match>
    <description>PCI DSS 6.6: Web application attack detected</description>
    <group>pci_dss_6.6,compliance,attack,ids,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- PCI 8.3: Authentication failures -->
  <rule id="120003" level="7">
    <if_group>authentication_failed</if_group>
    <description>PCI DSS 8.3: Authentication failure detected from $(data.srcip)</description>
    <group>pci_dss_8.3,compliance,authentication,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- PCI 8.3 brute force -->
  <rule id="120004" level="12">
    <if_group>brute_force</if_group>
    <description>PCI DSS 8.3: Brute force attack detected from $(data.srcip)</description>
    <group>pci_dss_8.3,compliance,brute_force,</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- PCI 10.2: Successful admin login -->
  <rule id="120005" level="5">
    <if_group>admin_login</if_group>
    <description>PCI DSS 10.2: Admin login event from $(data.srcip)</description>
    <group>pci_dss_10.2,compliance,authentication,</group>
  </rule>

  <!-- PCI 10.6: Malware detection -->
  <rule id="120006" level="10">
    <if_group>malware</if_group>
    <description>PCI DSS 10.6: Malware/threat detected</description>
    <group>pci_dss_10.6,compliance,malware,</group>
    <mitre>
      <id>T1204</id>
    </mitre>
  </rule>

  <!-- PCI 11.4: IDS alert -->
  <rule id="120007" level="8">
    <if_group>ids</if_group>
    <description>PCI DSS 11.4: Intrusion attempt detected</description>
    <group>pci_dss_11.4,compliance,ids,</group>
  </rule>

  <!-- ============================================================
       HIPAA — Health Insurance Portability and Accountability Act
  ============================================================ -->

  <!-- HIPAA 164.308: Unauthorized access attempt -->
  <rule id="120010" level="7">
    <if_group>authentication_failed</if_group>
    <description>HIPAA 164.308: Unauthorized access attempt from $(data.srcip)</description>
    <group>hipaa_164.308.a.5.ii.c,compliance,authentication,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- HIPAA 164.312: Transmission security -->
  <rule id="120011" level="8">
    <if_group>ids</if_group>
    <description>HIPAA 164.312: Potential PHI transmission security incident</description>
    <group>hipaa_164.312.e.2.ii,compliance,ids,</group>
    <mitre>
      <id>T1040</id>
    </mitre>
  </rule>

  <!-- HIPAA 164.312: Admin audit -->
  <rule id="120012" level="5">
    <if_group>admin_login</if_group>
    <description>HIPAA 164.312: Administrative access logged — $(data.username)</description>
    <group>hipaa_164.312.b,compliance,authentication,</group>
  </rule>

  <!-- ============================================================
       GDPR — General Data Protection Regulation
  ============================================================ -->

  <!-- GDPR Art 25: Access from external country (GeoIP enriched) -->
  <rule id="120020" level="7">
    <if_group>authentication_success</if_group>
    <field name="GeoLocation.country_name" type="pcre2">.+</field>
    <description>GDPR Art 25: Remote access from $(GeoLocation.country_name)</description>
    <group>gdpr_IV_25,compliance,authentication,</group>
  </rule>

  <!-- GDPR Art 32: Security incident -->
  <rule id="120021" level="10">
    <if_group>attack</if_group>
    <description>GDPR Art 32: Security incident detected</description>
    <group>gdpr_IV_32.1,compliance,attack,</group>
    <mitre>
      <id>T1190</id>
    </mitre>
  </rule>

  <!-- GDPR Art 33: Data breach notification trigger -->
  <rule id="120022" level="12">
    <if_group>malware</if_group>
    <description>GDPR Art 33: Potential data breach event — immediate review required</description>
    <group>gdpr_IV_33,compliance,malware,critical,</group>
    <mitre>
      <id>T1005</id>
    </mitre>
  </rule>

  <!-- GDPR Art 5: Audit trail — config change -->
  <rule id="120023" level="8">
    <if_group>config_changed</if_group>
    <description>GDPR Art 5: Configuration change detected from $(data.srcip)</description>
    <group>gdpr_IV_5.1.f,compliance,config_change,</group>
  </rule>

  <!-- ============================================================
       NIST 800-53 — US Federal Security Controls
  ============================================================ -->

  <!-- NIST AC-3: Access enforcement failures -->
  <rule id="120030" level="7">
    <if_group>authentication_failed</if_group>
    <description>NIST AC-3: Access control enforcement event from $(data.srcip)</description>
    <group>nist_800_53_AC.3,compliance,authentication,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- NIST AC-17: Remote access -->
  <rule id="120031" level="5">
    <if_group>vpn</if_group>
    <description>NIST AC-17: Remote access session from $(data.srcip)</description>
    <group>nist_800_53_AC.17,compliance,vpn,</group>
    <mitre>
      <id>T1133</id>
    </mitre>
  </rule>

  <!-- NIST AU-2: Audit events — attacks -->
  <rule id="120032" level="10">
    <if_group>attack</if_group>
    <description>NIST AU-2: Auditable security event — attack detected</description>
    <group>nist_800_53_AU.2,compliance,attack,</group>
  </rule>

  <!-- NIST AU-14: Session audit -->
  <rule id="120033" level="5">
    <if_group>admin_login</if_group>
    <description>NIST AU-14: Privileged session established — $(data.username)</description>
    <group>nist_800_53_AU.14,compliance,authentication,</group>
  </rule>

  <!-- NIST CM-7: Least functionality — blocked services -->
  <rule id="120034" level="5">
    <if_group>firewall_drop</if_group>
    <description>NIST CM-7: Unauthorized service blocked from $(data.srcip)</description>
    <group>nist_800_53_CM.7,compliance,firewall,</group>
  </rule>

  <!-- NIST IR-4: Incident handling — IDS alert -->
  <rule id="120035" level="10">
    <if_group>ids</if_group>
    <description>NIST IR-4: Security incident detected — requires incident response</description>
    <group>nist_800_53_IR.4,compliance,ids,attack,</group>
  </rule>

  <!-- NIST SC-5: Reconnaissance/scan detected -->
  <rule id="120036" level="8">
    <if_group>recon</if_group>
    <description>NIST SC-5: Reconnaissance attempt from $(data.srcip)</description>
    <group>nist_800_53_SC.5,compliance,recon,</group>
    <mitre>
      <id>T1046</id>
    </mitre>
  </rule>

  <!-- NIST SI-3: Malware protection -->
  <rule id="120037" level="12">
    <if_group>malware</if_group>
    <description>NIST SI-3: Malware detected</description>
    <group>nist_800_53_SI.3,compliance,malware,</group>
    <mitre>
      <id>T1204</id>
    </mitre>
  </rule>

  <!-- NIST SI-4: System monitoring — IDS events -->
  <rule id="120038" level="7">
    <if_group>ids</if_group>
    <description>NIST SI-4: System monitoring alert</description>
    <group>nist_800_53_SI.4,compliance,ids,</group>
  </rule>

  <!-- ============================================================
       TSC — SOC2 Trust Service Criteria
  ============================================================ -->

  <!-- TSC CC6.1: Logical access controls -->
  <rule id="120040" level="7">
    <if_group>authentication_failed</if_group>
    <description>TSC CC6.1: Logical access control failure from $(data.srcip)</description>
    <group>tsc_CC6.1,compliance,authentication,</group>
  </rule>

  <!-- TSC CC6.7: Transmission of data -->
  <rule id="120041" level="8">
    <if_group>exfiltration</if_group>
    <description>TSC CC6.7: Potential data exfiltration</description>
    <group>tsc_CC6.7,compliance,exfiltration,</group>
    <mitre>
      <id>T1048</id>
    </mitre>
  </rule>

  <!-- TSC CC7.1: System operations — IDS events -->
  <rule id="120042" level="8">
    <if_group>ids</if_group>
    <description>TSC CC7.1: Security incident affecting system operations</description>
    <group>tsc_CC7.1,compliance,ids,</group>
  </rule>

  <!-- TSC CC7.2: Monitoring — malware detection -->
  <rule id="120043" level="12">
    <if_group>malware</if_group>
    <description>TSC CC7.2: Malware detection event — review required</description>
    <group>tsc_CC7.2,compliance,malware,</group>
  </rule>

  <!-- TSC CC8.1: Change management -->
  <rule id="120044" level="8">
    <if_group>config_changed</if_group>
    <description>TSC CC8.1: Configuration change event from $(data.srcip)</description>
    <group>tsc_CC8.1,compliance,config_change,</group>
  </rule>

  <!-- ==============================================================
       DNS/INFOBLOX COMPLIANCE RULES — Added 2026-05-18
       Rule IDs: 120050–120074
       Covers: infoblox_threat, rpz_storm, dga_malware, dns_axfr,
               dns_nxdomain, dns_update_denied, dns_denied, dns_firewall,
               dhcp_flood, dhcp_pool_exhausted, dhcp_conflict,
               infoblox_audit, dns_record_change
  ============================================================== -->

  <rule id="120050" level="9">
    <if_sid>100430,100431,100432</if_sid>
    <description>PCI 11.4 / NIST SI.4: DNS Firewall blocked malicious domain</description>
    <group>pci_dss_11.4,nist_800_53_SI.4,tsc_CC7.1,compliance,dns,</group>
    <mitre>
      <id>T1071.004</id>
    </mitre>
  </rule>

  <rule id="120051" level="12">
    <if_sid>100433,100434</if_sid>
    <description>PCI 10.6 / NIST SI.3 / GDPR Art 32: Infected host detected via repeated malicious DNS activity</description>
    <group>pci_dss_10.6,nist_800_53_SI.3,gdpr_IV_32,tsc_CC7.2,compliance,malware,dns,</group>
    <mitre>
      <id>T1071.004</id>
    </mitre>
  </rule>

  <rule id="120052" level="11">
    <if_sid>100402,100403</if_sid>
    <description>PCI 11.4 / NIST SC.5: DNS Zone Transfer attempt detected</description>
    <group>pci_dss_11.4,nist_800_53_SC.5,compliance,recon,dns,</group>
    <mitre>
      <id>T1590.002</id>
    </mitre>
  </rule>

  <rule id="120053" level="12">
    <if_sid>100408</if_sid>
    <description>NIST SI.3 / GDPR Art 32: DGA malware activity detected from NXDOMAIN flood</description>
    <group>nist_800_53_SI.3,gdpr_IV_32,tsc_CC7.2,compliance,malware,dns,</group>
    <mitre>
      <id>T1568.002</id>
    </mitre>
  </rule>

  <!-- NXDOMAIN per-event overlay is noisy; DGA flood rule 120053 stays active. -->
  <rule id="120054" level="0">
    <if_sid>100407</if_sid>
    <description>NIST SC.5 / TSC CC7.1: DNS NXDOMAIN response anomaly detected</description>
    <group>nist_800_53_SC.5,tsc_CC7.1,compliance,dns,</group>
  </rule>

  <rule id="120055" level="8">
    <if_sid>100404</if_sid>
    <description>PCI 6.6 / NIST SC.5: DNS Dynamic Update denied</description>
    <group>pci_dss_6.6,nist_800_53_SC.5,compliance,dns,</group>
    <mitre>
      <id>T1584</id>
    </mitre>
  </rule>

  <rule id="120056" level="6">
    <if_sid>100406</if_sid>
    <description>NIST SC.5: Unauthorized DNS recursive query denied</description>
    <group>nist_800_53_SC.5,compliance,dns,access_control,</group>
  </rule>

  <rule id="120057" level="10">
    <if_sid>100426</if_sid>
    <description>TSC CC6.7 / GDPR Art 32 / HIPAA 164.312: DNS Firewall threat category match detected</description>
    <group>tsc_CC6.7,gdpr_IV_32,hipaa_164.312,compliance,dns,exfiltration,</group>
    <mitre>
      <id>T1071.004</id>
    </mitre>
  </rule>

  <rule id="120060" level="11">
    <if_sid>100418</if_sid>
    <description>NIST SC.5 / TSC CC7.1: DHCP flood detected</description>
    <group>nist_800_53_SC.5,tsc_CC7.1,compliance,dhcp,dos,</group>
    <mitre>
      <id>T1499</id>
    </mitre>
  </rule>

  <rule id="120061" level="13">
    <if_sid>100441,100442</if_sid>
    <description>NIST SC.5 / TSC CC7.2: DHCP pool exhausted</description>
    <group>nist_800_53_SC.5,tsc_CC7.2,compliance,dhcp,dos,critical,</group>
    <mitre>
      <id>T1499</id>
    </mitre>
  </rule>

  <rule id="120062" level="9">
    <if_sid>100417</if_sid>
    <description>PCI 1.3 / NIST SC.5: DHCP IP conflict detected</description>
    <group>pci_dss_1.3,nist_800_53_SC.5,compliance,dhcp,</group>
    <mitre>
      <id>T1557</id>
    </mitre>
  </rule>

  <rule id="120070" level="8">
    <if_sid>100422</if_sid>
    <description>PCI 8.3 / NIST AC.3 / HIPAA 164.308: Infoblox admin login failed</description>
    <group>pci_dss_8.3,nist_800_53_AC.3,hipaa_164.308,compliance,authentication,dns,</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <rule id="120071" level="13">
    <if_sid>100423</if_sid>
    <description>PCI 8.3 / NIST AC.3 / HIPAA 164.308 / TSC CC6.1: Infoblox admin brute force detected</description>
    <group>pci_dss_8.3,nist_800_53_AC.3,hipaa_164.308,tsc_CC6.1,compliance,brute_force,dns,</group>
    <mitre>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <rule id="120072" level="5">
    <if_sid>100421</if_sid>
    <description>PCI 10.2 / NIST AU.14: Infoblox admin login success</description>
    <group>pci_dss_10.2,nist_800_53_AU.14,compliance,authentication,dns,</group>
  </rule>

  <rule id="120073" level="8">
    <if_sid>100424</if_sid>
    <description>PCI 10.6 / NIST CM.7 / GDPR Art 5 / TSC CC8.1: Infoblox DNS record changed</description>
    <group>pci_dss_10.6,nist_800_53_CM.7,gdpr_IV_5,tsc_CC8.1,compliance,config_change,dns,</group>
    <mitre>
      <id>T1584.002</id>
    </mitre>
  </rule>

  <rule id="120074" level="7">
    <if_sid>100424</if_sid>
    <description>NIST CM.7 / TSC CC8.1: Infoblox configuration change event</description>
    <group>nist_800_53_CM.7,tsc_CC8.1,compliance,config_change,dns,</group>
  </rule>

</group>
